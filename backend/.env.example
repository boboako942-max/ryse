# Database
MONGO_URI=mongodb://localhost:27017/stylehub

# Server
PORT=7000
NODE_ENV=development
FRONTEND_URL=http://localhost:8000

# Stripe (Payment Processing)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayMongo (GCash & PayMaya)
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public_key
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Exchange Rate API
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# GCash Configuration
GCASH_API_KEY=your_gcash_api_key
GCASH_PUBLIC_KEY=your_gcash_public_key
GCASH_SECRET_KEY=your_gcash_secret_key

# AI Chat Support - OpenAI
# Get your API key from https://platform.openai.com/api-keys
# The chat widget will use mock responses if this key is not provided
OPENAI_API_KEY=your_openai_api_key

# ⚠️  SECURITY WARNING ⚠️
# NEVER commit actual secrets to version control!
# Use this file only as a template.
# Create a local .env file with your actual credentials.
# Add .env to .gitignore to prevent accidental commits.
